rg|rterm|Rog-O-Matic Pseudo Terminal,
	auto_right_margin, eat_newline_glitch, memory_below,
	columns#80, init_tabs#8, lines#24,
	bell=^G, carriage_return=^M, clear_screen=^L,
	clr_eol=\E^S,
	cursor_address=\Ea%p1%' '%+%c%p2%' '%+%c,
	cursor_down=\E<, cursor_left=^H, cursor_up=\E;,
	enter_standout_mode=\ED, exit_standout_mode=\Ed,
	key_backspace=^H, key_down=^J, key_left=^H, newline=^M^J,
	scroll_forward=^J, tab=^I,
